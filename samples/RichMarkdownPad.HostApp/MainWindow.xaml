<Window x:Class="RichMarkdownPad.HostApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controller="clr-namespace:RichMarkdownPad.Controller.Controls;assembly=RichMarkdownPad.Controller"
        mc:Ignorable="d"
        Title="RichMarkdownPad Host Sample" Height="600" Width="1000" MinHeight="420" MinWidth="720">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controller:MarkdownEditorControl Grid.Row="0"
                                          x:Name="EditorControl"
                                          OpenRequested="EditorControl_OnOpenRequested"
                                          SaveRequested="EditorControl_OnSaveRequested" />

        <Border Grid.Row="1" Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1,1,1,0" Padding="10,6">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="FileStatusText"
                           DockPanel.Dock="Left"
                           Margin="0,0,18,0"
                           VerticalAlignment="Center"
                           Text="File: Untitled" />
                <TextBlock x:Name="DirtyStatusText"
                           DockPanel.Dock="Left"
                           Margin="0,0,18,0"
                           VerticalAlignment="Center"
                           Text="Dirty: False" />
                <TextBlock x:Name="LastActionStatusText"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Text="Last Action: App Started" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
