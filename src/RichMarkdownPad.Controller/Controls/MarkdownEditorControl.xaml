<UserControl x:Class="RichMarkdownPad.Controller.Controls.MarkdownEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="8">
            <Button Content="Open" Width="70" Margin="0,0,8,0" Command="{Binding RequestOpenCommand}" />
            <Button Content="Save" Width="70" Margin="0,0,12,0" Command="{Binding RequestSaveCommand}" />
            <TextBlock VerticalAlignment="Center" Text="{Binding IsDirty, StringFormat=Dirty: {0}}" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 行番号ガター -->
                <Border Grid.Column="0"
                        Background="#F5F5F5"
                        BorderBrush="#DDD"
                        BorderThickness="1,1,1,1">
                    <ScrollViewer x:Name="LineNumberScroller"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsHitTestVisible="False"
                                  Focusable="False">
                        <TextBlock x:Name="LineNumberBlock"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   TextAlignment="Right"
                                   Padding="6,2,8,2"
                                   Foreground="#999" />
                    </ScrollViewer>
                </Border>

                <!-- エディター -->
                <TextBox x:Name="Editor"
                         Grid.Column="1"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="14"
                         TextWrapping="NoWrap"
                         Padding="6,2,4,2"
                         BorderThickness="0,1,1,1"
                         Text="{Binding DocumentText, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True" />

            <Border Grid.Column="2" Margin="8" BorderBrush="#DDD" BorderThickness="1">
                <wv2:WebView2 x:Name="PreviewBrowser" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
